# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Environment — never bake secrets into the image
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# Virtual environment — rebuilt inside the image
.venv/
venv/
env/

# Nested duplicate directory (shopos-agent/shopos-agent/)
shopos-agent/

# Generated outputs — mounted as volumes at runtime
output/*.json
output/*.html
reports/output/

# Node (if any tooling is added later)
node_modules/

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Test artefacts
.pytest_cache/
.coverage
htmlcov/
