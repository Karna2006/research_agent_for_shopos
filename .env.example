# Copy to .env and fill in your keys.
# Only GROQ_API_KEY is required — everything else is optional.

# ── LLM (required) ────────────────────────────────────────────────────────────
# Free key at https://console.groq.com
GROQ_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank → SQLite (./shopos.db) — good for development
# Set to Neon connection string → PostgreSQL (free at https://neon.tech)
# Format: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ── Caching (Upstash Redis) ───────────────────────────────────────────────────
# Leave blank → in-memory TTL cache (data lost on restart)
# Free tier at https://upstash.com — 10,000 requests/day, 256 MB
# Both vars must be set together; leaving either blank disables Redis.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── Mastra integration ────────────────────────────────────────────────────────
# Shared secret between Python and Mastra — must match in both services
# Generate with: openssl rand -hex 32
INTERNAL_SECRET_KEY=dev-internal-key-change-in-prod

# URL where the Mastra server is running (default: localhost for local dev)
# In Docker Compose this is overridden to http://mastra:4111 automatically
MASTRA_URL=http://localhost:4111

# LibSQL URL for Mastra brand memory persistence (default: local file)
LIBSQL_URL=file:./brand_memory.db

# ── Optional ──────────────────────────────────────────────────────────────────
# Improves PageSpeed Insights rate limits (unauthenticated endpoint still works)
PAGESPEED_API_KEY=
