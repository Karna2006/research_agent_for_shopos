# Copy to .env and fill in values.
# Only GROQ_API_KEY is required to run live audits.

# ── LLM (required for live audits) ────────────────────────────────────────────
# Free at https://console.groq.com — 14k requests/day, no credit card needed
GROQ_API_KEY=

# ── LLM fallbacks (optional) ──────────────────────────────────────────────────
# Gemini 2.0 Flash — third-tier fallback when Groq is exhausted
# Free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter — primary tier (higher quality, paid)
# Get at https://openrouter.ai
OPENROUTER_API_KEY=

# ── Meta Ads Library (optional but recommended) ────────────────────────────────
# Enables structured ad data instead of browser scraping.
# Get a free token: developers.facebook.com → Tools → Graph API Explorer → Generate Token
# Token expires — regenerate when you see "Token invalid" in the Ads section.
META_AD_LIBRARY_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank → SQLite (./shopos.db) — works out of the box
# Set to Neon PostgreSQL URL for production persistence
# Format: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ── PageSpeed API ─────────────────────────────────────────────────────────────
# Improves rate limits for the Store & CRO section (unauthenticated still works)
# Free at https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# ── Research: Tracxn funding data ─────────────────────────────────────────────
# Enables startup funding stage in the Research section (paid API)
TRACXN_API_KEY=

# ── Neural engagement: Meta TRIBE v2 ──────────────────────────────────────────
# Enables Deep Visual Analysis in Social Media Audit (fMRI-style Reels scoring).
# Install: cd ../tribeV2 && pip install -e .
# Then set this to your local checkpoint dir or HuggingFace repo id
TRIBE_CHECKPOINT_DIR=

# TRIBE tuning (all optional — defaults shown):
# TRIBE_HOOK_SECONDS=9        — analyse only first N seconds of a Reel (0 = full video)
# TRIBE_FULL_PIPELINE=0       — set to 1 on GPU machine to enable language features
# TRIBE_SIM_DPI=300           — brain map render resolution
# TRIBE_SIM_MESH=fsaverage3   — FreeSurfer mesh detail (fsaverage3/4/5)
# TRIBE_SIM_VIEW=left         — brain hemisphere to render (left/right/both)

# ── NVIDIA NIM (optional — higher-quality vision LLM for visual analysis) ──────
# Enables MiniMax vision model via NVIDIA NIM API as LLM fallback tier.
# Get at https://build.nvidia.com
NVIDIA_API_KEY=

# ── Internal (leave as-is for local dev) ──────────────────────────────────────
INTERNAL_SECRET_KEY=dev-internal-key-change-in-prod

# ── Mastra dashboard (optional — for workflow observability UI) ────────────────
# Set this to enable the Mastra dashboard at localhost:4111.
# Python LangGraph ALWAYS runs regardless. Mastra only adds dashboard visibility.
# To start: cd mastra && npm run dev   (or: make mastra / make dev-full)
# Leave blank to disable all Mastra notifications (default for production).
MASTRA_URL=
